# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenAI (fallback analysis) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── News Sources ─────────────────────────────────────────────────────────────
NEWS_API_KEY=...                  # newsapi.org
GNEWS_API_KEY=...                 # gnews.io

# ─── Social Media ─────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=...          # X/Twitter API v2
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=NVCTrader/1.0

# ─── Market Data ──────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=...         # alphavantage.co
FRED_API_KEY=...                  # fred.stlouisfed.org (free)

# ─── Database ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=...
UPSTASH_REDIS_TOKEN=...

# ─── OANDA Broker (PRIMARY — works from cloud, no MT5 needed) ─────────────────
# Sign up free demo: https://www.oanda.com/register/#/sign-up/demo
OANDA_API_KEY=...                 # Settings → API Access → Generate
OANDA_ACCOUNT_ID=...              # e.g. 001-001-1234567-001
OANDA_LIVE=false                  # Set true ONLY for live trading

# ─── MT5 Bridge (OPTIONAL — for MT5 Expert Advisor on Windows VPS) ────────────
ZMQ_SIGNAL_PORT=5555              # Python → MT5 (PUSH)
ZMQ_FILL_PORT=5556                # MT5 → Python (PULL)
ZMQ_HOST=localhost                # or Windows VPS IP

# ─── Risk Parameters ──────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE_PCT=1.0        # % of account per trade
MAX_DAILY_DRAWDOWN_PCT=3.0        # pause at 3% daily loss
MAX_WEEKLY_DRAWDOWN_PCT=6.0
MAX_MONTHLY_DRAWDOWN_PCT=10.0
MAX_OPEN_TRADES=8
SIGNAL_THRESHOLD=0.60             # minimum score to trade

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=...                # for JWT signing

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=...
LOG_LEVEL=INFO
